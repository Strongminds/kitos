# KITOS Docker Compose - Environment Variables
# Copy this file to .env and fill in the values.
# Usage: cp .env.example .env

# ─── Certificate Passwords ───────────────────────────────────────────────────
# Passwords for the PFX certificate files mounted into the kitos-api container.
# The PFX files should be placed in the ./certs/ directory.

# SSO Service Provider certificate file name (./certs/kitos-local-pfx)
SSO_CERT_FILE_NAME=kitos-local-pfx
# STS (Adgangsstyring) certificate file name (./certs/ADG_EXTTEST_Adgangsstyring_2)
STS_CERT_FILE_NAME=ADG_EXTTEST_Adgangsstyring_2
# STS Organisation certificate file name (./certs/ORG_EXTTEST_Organisation_2)
STS_ORG_CERT_FILE_NAME=ORG_EXTTEST_Organisation_2

# SSO Service Provider certificate password
SSO_CERT_PASSWORD=
# STS (Adgangsstyring) certificate password
STS_CERT_PASSWORD=
# STS Organisation certificate password
STS_ORG_CERT_PASSWORD=

# Certificate thumbprints used to identify mounted certs
SSO_CERT_THUMBPRINT=
STS_CERT_THUMBPRINT=
STS_ORG_CERT_THUMBPRINT=
