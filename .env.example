# KITOS Docker Compose - Environment Variables
# Copy this file to .env and fill in the values.
# Usage: cp .env.example .env

# ─── Certificate Passwords ───────────────────────────────────────────────────
# Passwords for the PFX certificate files mounted into the kitos-api container.
# The PFX files should be placed in the ./certs/ directory.

# SSO Service Provider certificate (./certs/sso-sp.pfx)
SSO_CERT_PASSWORD=

# STS (Adgangsstyring) certificate (./certs/sts.pfx)
STS_CERT_PASSWORD=

# STS Organisation certificate (./certs/sts-org.pfx)
STS_ORG_CERT_PASSWORD=
