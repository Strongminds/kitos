<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <AssemblyName>Tools.SSOWithKombitSts</AssemblyName>
    <RootNamespace>Tools.SSOWithKombitSts</RootNamespace>
  </PropertyGroup>
  <!-- kitos.dk.nita.saml20 is built against Microsoft.AspNetCore.App; declare the same
       FrameworkReference so the ASP.NET Core types are available at runtime. -->
  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="kitos.dk.nita.saml20" Version="1.1.8" />
  </ItemGroup>
  <ItemGroup>
    <None Update="SamlMetadataTemplate.xml">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </None>
  </ItemGroup>
</Project>

